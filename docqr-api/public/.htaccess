# Configuración para PRODUCCIÓN
# IMPORTANTE: Ajustar CORS según el dominio de producción

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # CRÍTICO: NO interceptar /auth/login-download-file/ aquí
    # Dejar que el .htaccess dentro de public/auth/login-download-file/ lo maneje
    # El .htaccess de la carpeta específica tiene prioridad y captura todo
    # NO agregar reglas aquí para /auth/login-download-file/
    
    # Forzar HTTPS en producción
    # IMPORTANTE: Solo descomentar si el servidor NO tiene SSL/TLS configurado en el VirtualHost
    # Si ya tienes HTTPS configurado en Apache/Nginx, DEJAR COMENTADO para evitar redirecciones dobles
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
    
    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
    
    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]
    
    # CRÍTICO: Forzar que todas las rutas /api/* pasen a Laravel
    # Esto asegura que las rutas de API no sean interceptadas por el servidor
    RewriteCond %{REQUEST_URI} ^/api/
    RewriteRule ^(.*)$ index.php [L,QSA]
    
    # CRÍTICO: Forzar que /doc/ pase a Laravel
    # Esta ruta es usada para redirigir documentos desde /auth/login-download-file/
    RewriteCond %{REQUEST_URI} ^/doc/
    RewriteRule ^(.*)$ index.php [L,QSA]
    
    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

# Disable Directory Browsing
Options -Indexes

# CRÍTICO para LiteSpeed: Para /auth/login-download-file/ priorizar index.html
# Para otras rutas, priorizar index.php
DirectoryIndex index.php index.html index.htm

# Forzar ejecución de PHP en archivos .php (especialmente para LiteSpeed)
<FilesMatch "\.php$">
    SetHandler application/x-httpd-php
</FilesMatch>

# Security Headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Cache Control
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType application/pdf "access plus 1 month"
</IfModule>

# CORS Headers - PRODUCCIÓN
# IMPORTANTE: Ajustar según el dominio de producción
<IfModule mod_headers.c>
    # Permitir desde el dominio de producción
    # Incluir todos los subdominios relacionados (docqr, docqr-api, etc.)
    SetEnvIf Origin "^https?://(www\.)?(docqr(-api)?\.geofal\.com\.pe|geofal\.com\.pe)$" AccessControlAllowOrigin=$0
    Header always set Access-Control-Allow-Origin %{AccessControlAllowOrigin}e env=AccessControlAllowOrigin
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, PATCH, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Accept, Authorization, X-Requested-With, X-CSRF-TOKEN"
    Header always set Access-Control-Allow-Credentials "true"
    
    # Manejar preflight OPTIONS
    <IfModule mod_rewrite.c>
        RewriteCond %{REQUEST_METHOD} OPTIONS
        RewriteRule ^(.*)$ $1 [R=200,L]
    </IfModule>
</IfModule>

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php83” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php83 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
